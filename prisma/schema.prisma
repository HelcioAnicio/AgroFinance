generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String          @id @default(dbgenerated("gen_random_uuid()"))
  name          String
  email         String          @unique
  cnpj          String?         @unique
  password      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  emailVerified DateTime?
  image         String?
  activeFarmId  String?
  activeFarm    Farm?           @relation("UserActiveFarm", fields: [activeFarmId], references: [id])
  accounts      Account[]
  animals       Animal[]
  Authenticator Authenticator[]
  Notification  Notification[]
  animalStatusHistories AnimalStatusHistory[]
  calfLossHistories AnimalCalfLossHistory[]
  externalBulls ExternalBull[]
  farmMemberships FarmMembership[]
  sentFarmInvites FarmInvite[]  @relation("FarmInviteInviter")
  acceptedInvites FarmInvite[]  @relation("FarmInviteAccepter")
  auditLogs        AuditLog[]
  transactions     Transaction[]
  sessions         Session[]
  pushSubscriptions PushSubscription[]
}

enum FarmRole {
  OWNER
  MANAGER
  EMPLOYEE
  CAREGIVER_VETERINARIAN
  FINANCIAL
  VIEWER
}

enum FarmInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Farm {
  id                    String          @id @default(dbgenerated("gen_random_uuid()"))
  name                  String
  ownerUserId           String
  trialStartedAt        DateTime        @default(now())
  trialEndsAt           DateTime
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  stripeSubscriptionItemId  String?
  subscriptionStatus        SubscriptionStatus @default(TRIALING)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  animals               Animal[]
  externalBulls         ExternalBull[]
  transactions          Transaction[]
  memberships           FarmMembership[]
  invites               FarmInvite[]
  auditLogs             AuditLog[]
  activeForUsers        User[]           @relation("UserActiveFarm")

  @@index([ownerUserId])
}

model FarmMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  farmId    String
  userId    String
  role      FarmRole @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([farmId, userId])
  @@index([userId])
}

model FarmInvite {
  id             String           @id @default(dbgenerated("gen_random_uuid()"))
  farmId         String
  email          String
  role           FarmRole
  token          String           @unique
  status         FarmInviteStatus @default(PENDING)
  invitedById    String
  acceptedById   String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  farm           Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation("FarmInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy     User?            @relation("FarmInviteAccepter", fields: [acceptedById], references: [id])

  @@index([farmId, status])
  @@index([email])
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  farmId      String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([farmId, createdAt])
  @@index([entityType, entityId])
}

model Animal {
  id                    String         @id @default(dbgenerated("gen_random_uuid()"))
  manualId              String
  gender                String
  birthDate             DateTime
  weight                Float
  breed                 String
  category              String         @default("") @map("category")
  motherId              String?
  fatherId              String?
  reproductiveStatus    String?
  handlingType          String?
  bullId                String?
  protocol              String?
  andrological          String?
  expectedDueDate       DateTime?
  fetalGender           String?
  bodyConditionScore    Float?
  observations          String?
  ownerId               String
  farmId                String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  dewormingDate         DateTime?
  dewormingExpiry       DateTime?
  dewormingName         String?
  status                String         @default("active")
  isForFattening        Boolean        @default(false)
  pevExpiresAt          DateTime?
  vaccineDate           DateTime?
  vaccineExpiry         DateTime?
  vaccineName           String?
  bullIatfId            String?
  externalBullId        String?
  externalBullIatfId    String?
  bull                  Animal?        @relation("BullHandling", fields: [bullId], references: [id])
  offspringFromBull     Animal[]       @relation("BullHandling")
  father                Animal?        @relation("FatherOffspring", fields: [fatherId], references: [id])
  offspringFromFather   Animal[]       @relation("FatherOffspring")
  mother                Animal?        @relation("MotherOffspring", fields: [motherId], references: [id])
  offspringFromMother   Animal[]       @relation("MotherOffspring")
  owner                 User           @relation(fields: [ownerId], references: [id])
  farm                  Farm?          @relation(fields: [farmId], references: [id], onDelete: SetNull)
  bullIatfRel           Animal?        @relation("BullIatfHandling", fields: [bullIatfId], references: [id])
  offspringFromBullIatf Animal[]       @relation("BullIatfHandling")
  externalBull          ExternalBull?  @relation("ExternalBullHandling", fields: [externalBullId], references: [id])
  externalBullIatfRel   ExternalBull?  @relation("ExternalBullIatfHandling", fields: [externalBullIatfId], references: [id])
  dewormings            Deworming[]    @relation("AnimalDewormings")
  diseases              Disease[]      @relation("AnimalDiseases")
  Notification          Notification[]
  vaccines              Vaccine[]      @relation("AnimalVaccines")
  weightHistories       AnimalWeightHistory[]
  statusHistories       AnimalStatusHistory[]
  calfLossHistories     AnimalCalfLossHistory[] @relation("AnimalCalfLossMother")
  calfLossFatherHistories AnimalCalfLossHistory[] @relation("AnimalCalfLossFather")
  reproductionManagements ReproductionManagement[]

  @@unique([manualId, ownerId])
  @@index([farmId])
}

model ExternalBull {
  id               String   @id @default(dbgenerated("gen_random_uuid()"))
  name             String
  breed            String
  batches          String[]
  sourceCompany    String
  dosesAvailable   Int
  ownerId          String
  farmId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  farm             Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)
  usedInHandling   Animal[] @relation("ExternalBullHandling")
  usedInIatf       Animal[] @relation("ExternalBullIatfHandling")
  calfLossHistories AnimalCalfLossHistory[]

  @@index([ownerId])
  @@index([farmId])
}

model AnimalCalfLossHistory {
  id              String       @id @default(dbgenerated("gen_random_uuid()"))
  animalId        String
  ownerId         String
  previousStatus  String?
  newStatus       String
  expectedDueDate DateTime?
  lossDate        DateTime
  reason          String?
  fatherType      String
  fatherAnimalId  String?
  externalBullId  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  animal          Animal       @relation("AnimalCalfLossMother", fields: [animalId], references: [id], onDelete: Cascade)
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fatherAnimal    Animal?      @relation("AnimalCalfLossFather", fields: [fatherAnimalId], references: [id], onDelete: SetNull)
  externalBull    ExternalBull? @relation(fields: [externalBullId], references: [id], onDelete: SetNull)

  @@index([animalId, lossDate])
  @@index([ownerId, createdAt])
  @@map("animal_calf_loss_history")
}

model AnimalStatusHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  animalId       String
  ownerId        String
  previousStatus String?
  newStatus      String
  reason         String?
  changedAt      DateTime @default(now())
  year           Int
  month          Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  animal         Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, year, month])
  @@index([animalId, changedAt])
  @@map("animal_status_history")
}

enum WeightRecordType {
  PN
  PS
  PD
  PA
  OTHER
}

enum TransactionType {
  income
  expense

  @@map("transaction_type")
}

model AnimalWeightHistory {
  id         String           @id @default(dbgenerated("gen_random_uuid()"))
  animalId   String
  weight     Float
  recordType WeightRecordType @default(OTHER)
  measuredAt DateTime
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  animal     Animal           @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, measuredAt])
}

model Disease {
  id          String   @id @default(uuid())
  name        String
  description String?
  date        DateTime
  animalId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  animal      Animal   @relation("AnimalDiseases", fields: [animalId], references: [id])
}

model Vaccine {
  name        String
  description String?
  date        DateTime
  animalId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiryDate  DateTime
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  animal      Animal   @relation("AnimalVaccines", fields: [animalId], references: [id])

}

model Deworming {
  id        String   @id @default(uuid())
  name      String
  date      DateTime
  animalId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  animal    Animal   @relation("AnimalDewormings", fields: [animalId], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message   String
  notifyAt  DateTime @db.Timestamp(6)
  read      Boolean  @default(false)
  userId    String
  animalId  String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  Animal    Animal?  @relation(fields: [animalId], references: [id], onDelete: Cascade, map: "fk_notification_animal")
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_notification_user")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @map("userId")
  farmId      String?
  type        TransactionType
  category    String
  amount      Decimal         @db.Decimal(14, 2)
  date        DateTime        @db.Date
  description String?
  status      Boolean         @default(false)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm        Farm?           @relation(fields: [farmId], references: [id], onDelete: SetNull)

  @@index([userId], map: "transactions_user_id_idx")
  @@index([farmId], map: "transactions_farm_id_idx")
  @@index([userId, date(sort: Desc)], map: "transactions_user_id_date_idx")
  @@index([userId, type], map: "transactions_user_id_type_idx")
  @@map("transactions")
}

model ReproductionManagement {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  animalId      String
  stage         String   // D0, Manejo, Insemination, DG
  date          DateTime
  protocolo     Boolean? // for D0 and subsequent
  implant       String?  // for D0
  obs           String?
  ecc           Float?
  touroId       String?  // for Insemination, can be Animal.id or ExternalBull.id
  touroType     String?  // 'internal' or 'external'
  partida       String?  // for Insemination
  cio           String?  // for Insemination
  ressinc       Boolean? // for DG
  ressincCount  Int      @default(0)
  ressincHistory Json?   // array of {date: string, obs: string}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  animal        Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, stage])
}
